---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Items">
  <div class="max-w-4xl mx-auto">
    <div class="flex justify-between items-center mb-8">
      <h1 class="text-3xl font-bold">My Items</h1>
      <button
        id="create-btn"
        class="bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700"
      >
        Create Item
      </button>
    </div>

    <div id="auth-warning" class="hidden bg-yellow-100 border border-yellow-400 text-yellow-700 px-4 py-3 rounded mb-4">
      Please <a href="/login" class="underline font-medium">login</a> to view and manage items.
    </div>

    <div id="loading" class="text-center py-12">
      <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div>
      <p class="mt-2 text-gray-600">Loading items...</p>
    </div>

    <div id="items-container" class="hidden space-y-4"></div>

    <div id="empty-state" class="hidden text-center py-12 bg-white rounded-lg shadow-md">
      <div class="text-gray-400 text-6xl mb-4">📝</div>
      <h3 class="text-xl font-medium text-gray-700 mb-2">No items yet</h3>
      <p class="text-gray-500 mb-4">Create your first item to get started</p>
      <button
        class="bg-blue-600 text-white px-6 py-2 rounded-md hover:bg-blue-700"
        onclick="document.getElementById('create-btn').click()"
      >
        Create Item
      </button>
    </div>
  </div>

  <!-- Create/Edit Modal -->
  <div id="item-modal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
    <div class="bg-white rounded-lg p-8 max-w-md w-full mx-4">
      <h2 id="modal-title" class="text-2xl font-bold mb-4">Create Item</h2>
      
      <form id="item-form" class="space-y-4">
        <input type="hidden" id="item-id" />
        
        <div>
          <label for="title" class="block text-sm font-medium text-gray-700 mb-1">
            Title
          </label>
          <input
            type="text"
            id="title"
            name="title"
            required
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
          />
        </div>

        <div>
          <label for="description" class="block text-sm font-medium text-gray-700 mb-1">
            Description
          </label>
          <textarea
            id="description"
            name="description"
            rows="4"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
          ></textarea>
        </div>

        <div id="modal-error" class="hidden bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded text-sm"></div>

        <div class="flex space-x-3">
          <button
            type="submit"
            class="flex-1 bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700"
          >
            Save
          </button>
          <button
            type="button"
            id="cancel-btn"
            class="flex-1 bg-gray-200 text-gray-800 py-2 px-4 rounded-md hover:bg-gray-300"
          >
            Cancel
          </button>
        </div>
      </form>
    </div>
  </div>

  <script>
    import { items, getToken } from '../lib/api';

    const itemsContainer = document.getElementById('items-container') as HTMLDivElement;
    const loading = document.getElementById('loading') as HTMLDivElement;
    const emptyState = document.getElementById('empty-state') as HTMLDivElement;
    const authWarning = document.getElementById('auth-warning') as HTMLDivElement;
    const modal = document.getElementById('item-modal') as HTMLDivElement;
    const modalTitle = document.getElementById('modal-title') as HTMLHeadingElement;
    const itemForm = document.getElementById('item-form') as HTMLFormElement;
    const itemIdInput = document.getElementById('item-id') as HTMLInputElement;
    const titleInput = document.getElementById('title') as HTMLInputElement;
    const descriptionInput = document.getElementById('description') as HTMLTextAreaElement;
    const modalError = document.getElementById('modal-error') as HTMLDivElement;

    let currentItems: any[] = [];

    // Check authentication
    function checkAuth() {
      const token = getToken();
      if (!token) {
        loading.classList.add('hidden');
        authWarning.classList.remove('hidden');
        return false;
      }
      return true;
    }

    // Load items
    async function loadItems() {
      if (!checkAuth()) return;

      try {
        loading.classList.remove('hidden');
        itemsContainer.classList.add('hidden');
        emptyState.classList.add('hidden');

        currentItems = await items.getAll();
        
        if (currentItems.length === 0) {
          emptyState.classList.remove('hidden');
        } else {
          renderItems();
          itemsContainer.classList.remove('hidden');
        }
      } catch (error) {
        console.error('Error loading items:', error);
        authWarning.classList.remove('hidden');
      } finally {
        loading.classList.add('hidden');
      }
    }

    // Render items
    function renderItems() {
      itemsContainer.innerHTML = currentItems.map(item => `
        <div class="bg-white p-6 rounded-lg shadow-md">
          <div class="flex justify-between items-start">
            <div class="flex-1">
              <h3 class="text-xl font-bold mb-2">${escapeHtml(item.title)}</h3>
              ${item.description ? `<p class="text-gray-600 mb-4">${escapeHtml(item.description)}</p>` : ''}
              <p class="text-sm text-gray-400">Created: ${new Date(item.created_at).toLocaleDateString()}</p>
            </div>
            <div class="flex space-x-2">
              <button
                class="text-blue-600 hover:text-blue-800 px-3 py-1 rounded"
                onclick="editItem(${item.id})"
              >
                Edit
              </button>
              <button
                class="text-red-600 hover:text-red-800 px-3 py-1 rounded"
                onclick="deleteItem(${item.id})"
              >
                Delete
              </button>
            </div>
          </div>
        </div>
      `).join('');
    }

    // Escape HTML
    function escapeHtml(text: string): string {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    // Show modal
    function showModal(item?: any) {
      modalError.classList.add('hidden');
      
      if (item) {
        modalTitle.textContent = 'Edit Item';
        itemIdInput.value = item.id;
        titleInput.value = item.title;
        descriptionInput.value = item.description || '';
      } else {
        modalTitle.textContent = 'Create Item';
        itemIdInput.value = '';
        itemForm.reset();
      }
      
      modal.classList.remove('hidden');
    }

    // Hide modal
    function hideModal() {
      modal.classList.add('hidden');
      itemForm.reset();
    }

    // Edit item
    (window as any).editItem = (id: number) => {
      const item = currentItems.find(i => i.id === id);
      if (item) showModal(item);
    };

    // Delete item
    (window as any).deleteItem = async (id: number) => {
      if (!confirm('Are you sure you want to delete this item?')) return;

      try {
        await items.delete(id);
        await loadItems();
      } catch (error) {
        alert('Error deleting item: ' + (error instanceof Error ? error.message : 'Unknown error'));
      }
    };

    // Event listeners
    document.getElementById('create-btn')?.addEventListener('click', () => showModal());
    document.getElementById('cancel-btn')?.addEventListener('click', hideModal);

    itemForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      modalError.classList.add('hidden');

      const formData = new FormData(itemForm);
      const title = formData.get('title') as string;
      const description = formData.get('description') as string;
      const id = itemIdInput.value;

      try {
        if (id) {
          await items.update(parseInt(id), title, description);
        } else {
          await items.create(title, description);
        }
        
        hideModal();
        await loadItems();
      } catch (error) {
        modalError.textContent = error instanceof Error ? error.message : 'Error saving item';
        modalError.classList.remove('hidden');
      }
    });

    // Load items on page load
    loadItems();
  </script>
</BaseLayout>
